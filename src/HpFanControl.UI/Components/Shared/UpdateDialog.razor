@using Markdig
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.SystemUpdateAlt" Class="mr-2" />
            Update Available: @_version
        </MudText>
    </TitleContent>
    
    <DialogContent>
        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mt-2">Fetching release notes...</MudText>
            </MudStack>
        }
        else
        {
            <MudPaper Elevation="0" Class="pa-3 mb-2 mud-background-gray rounded" MaxHeight="500px" Style="overflow-y: auto;">
                <div class="mud-typography mud-typography-body2 px-2">
                    @((MarkupString)Markdown.ToHtml(_releaseNotes ?? "No release notes available."))
                </div>
            </MudPaper>
            <MudText Typo="Typo.caption" Color="Color.Error">
                Note: The application will close automatically to apply the update.
            </MudText>
        }
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Update" Disabled="@_isLoading">
            Install Update
        </MudButton>
    </DialogActions>
</MudDialog>