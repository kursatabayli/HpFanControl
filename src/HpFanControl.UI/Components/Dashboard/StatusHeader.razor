<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">

    <MudAvatar Variant="Variant.Filled" Color="Color.Primary" Rounded="true" Size="Size.Medium" Class="mud-elevation-4">
        <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" Color="Color.Inherit" OnClick="() => OpenSettings()"/>
    </MudAvatar>

    <MudStack Spacing="0">
        <MudText Typo="Typo.h6" Class="fw-bold lh-sm">
            HP CONTROL
        </MudText>

        <MudText Typo="Typo.caption" Color="Color.Primary" Class="fw-bold text-uppercase ls-1">
            @_currentModeName
        </MudText>
    </MudStack>

    <MudSpacer />

    <UpdateNotification />

</MudStack>