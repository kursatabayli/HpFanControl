@page "/"
@using HpFanControl.UI.Services
@using HpFanControl.UI.Interop
@using HpFanControl.UI.Helpers

<MudThemeProvider Theme="@_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="true" Elevation="1" @onmousedown="HandleAppBarMouseDown">
        <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small" Class="mr-2 ml-2" />
        <MudText Typo="Typo.subtitle2">HP FAN CONTROL</MudText>

        <MudSpacer />

        <MudButtonGroup class="ml-4" Color="Color.Primary" Variant="Variant.Text" @onmousedown:stopPropagation="true" @ondblclick:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Inherit"
                           OnClick="MinimizeWindow" />
            <MudIconButton Icon="@Icons.Material.Filled.CropSquare" Size="Size.Small" Color="Color.Inherit"
                           OnClick="MaximizeWindow" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                           OnClick="HideWindow" />
        </MudButtonGroup>
    </MudAppBar>

    <MudDivider Class="ma-8" />

    <MudMainContent Class="pa-8">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge">
            <MudGrid Spacing="6">

                <MudItem xs="12" md="4" lg="3">
                    <MudStack Spacing="4">

                        <MudPaper Elevation="4" Class="pa-5">
                            <MudStack Spacing="4">
                                <StatusHeader />
                                <MudDivider />
                                <ModeSelector />
                            </MudStack>
                        </MudPaper>

                        <MudText Typo="Typo.overline" Color="Color.Primary" Class="px-2 fw-bold">
                            REAL-TIME SENSORS
                        </MudText>

                        <StatsDisplay />

                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="8" lg="9">
                    <MudPaper Elevation="1" Outlined="true" Class="pa-4 mud-height-full">
                        <FanCurvePanel />
                    </MudPaper>
                </MudItem>

            </MudGrid>
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div class="resize-corner nw" @onmousedown="() => StartResize(0)"></div>
<div class="resize-edge top" @onmousedown="() => StartResize(1)"></div>
<div class="resize-corner ne" @onmousedown="() => StartResize(2)"></div>
<div class="resize-edge left" @onmousedown="() => StartResize(3)"></div>
<div class="resize-edge right" @onmousedown="() => StartResize(4)"></div>
<div class="resize-corner sw" @onmousedown="() => StartResize(5)"></div>
<div class="resize-edge bottom" @onmousedown="() => StartResize(6)"></div>
<div class="resize-corner se" @onmousedown="() => StartResize(7)"></div>

@code {
    [Inject] private WindowActionService WindowService { get; set; }
    private readonly IntPtr gtkWindow = GtkWindowHelper.GetMainWindowPointer();
    private MudTheme _theme = new();
    protected override void OnInitialized()
    {
        _theme = new()
        {
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties() { DefaultBorderRadius = "6px" }
        };
    }

    private void HideWindow() => WindowService.OnHideRequested?.Invoke();
    private void MinimizeWindow() => WindowService.OnMinimizeRequested?.Invoke();
    private void MaximizeWindow() => WindowService.OnMaximizeRequested?.Invoke();

    private void DragMove() => NativeMethods.gtk_window_begin_move_drag(gtkWindow, 1, 0, 0, 0);

    private void HandleAppBarMouseDown(MouseEventArgs e)
    {
        if (e.Detail == 2) 
            MaximizeWindow();
        else
            DragMove(); 
    }

    private void StartResize(int edge) => WindowService.OnResizeRequested?.Invoke(edge);

    private readonly PaletteDark _darkPalette = new()
{
    Primary = "#3B82F6",
    Secondary = "#8B5CF6",
    
    Background = "#11111A", 
    Surface = "#1C1C26",
    AppbarBackground = "#11111A", 
    
    AppbarText = "#F1F5F9",
    TextPrimary = "#F1F5F9",
    TextSecondary = "#94A3B8",
    TextDisabled = "#475569",
    
    DrawerBackground = "#16161F",
    DrawerText = "#F1F5F9",
    DrawerIcon = "#94A3B8",
    
    ActionDefault = "#94A3B8",
    ActionDisabled = "#334155",
    ActionDisabledBackground = "#191924",
    LinesDefault = "#2D2D3A",
    TableLines = "#2D2D3A",
    Divider = "#2D2D3A",
    
    OverlayLight = "rgba(59, 130, 246, 0.05)",
    
    Info = "#0EA5E9",
    Success = "#10B981",
    Warning = "#F59E0B",
    Error = "#EF4444",
    
    Black = "#050505",
    White = "#FFFFFF"
};
}